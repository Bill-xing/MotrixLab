    <motor class="HAA" name="RF_HAA" joint="RF_HAA" ctrllimited="true" ctrlrange="-80 80"/>
    <motor class="HFE" name="RF_HFE" joint="RF_HFE" ctrllimited="true" ctrlrange="-80 80"/>
